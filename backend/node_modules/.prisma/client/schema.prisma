generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  language  String   @default("fr")
  createdAt DateTime @default(now())
  houses    House[]
}

model House {
  id            String              @id @default(cuid())
  name          String
  location      String
  bedrooms      Int
  pricePerNight Float
  color         String
  photoUrl      String?
  photos        String              @default("[]")
  amenities     String              @default("[]")
  description   String?
  ownerId       String
  owner         User                @relation(fields: [ownerId], references: [id])
  bookings      Booking[]
  monthlyPrices HouseMonthlyPrice[]
  createdAt     DateTime            @default(now())
}

model HouseMonthlyPrice {
  id      String @id @default(cuid())
  houseId String
  month   Int
  price   Float
  house   House  @relation(fields: [houseId], references: [id])

  @@unique([houseId, month])
}

model Booking {
  id          String   @id @default(cuid())
  guestName   String
  phone       String
  checkIn     DateTime
  checkOut    DateTime
  totalAmount Float
  amountPaid  Float    @default(0)
  status      String   @default("confirmed")
  notes       String?
  persons     Int?
  houseId     String
  house       House    @relation(fields: [houseId], references: [id])
  createdAt   DateTime @default(now())
}
